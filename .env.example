# Copy this file to .env before running.
# Never commit your real .env, private key, wallet address, logs, CSVs, or order state.

PYTHONIOENCODING=utf-8
PYTHONUNBUFFERED=1

# Runtime
POLY_RUN_ONCE=true
POLY_SCAN_LIMIT=200
POLY_MAX_PAGES=60
POLY_SLEEP_SECONDS=300
POLY_VERBOSE=false

# Mode
# Keep false for dry-run/paper mode. Set true only after you understand the risks.
POLY_AUTO_ORDER=false
POLY_ONLY_TODAY=false

# Wallet / API - fill in locally only
POLY_PRIVATE_KEY=
POLY_FUNDER=
POLY_SIGNATURE_TYPE=2
POLY_CHAIN_ID=137

# Files
POLY_LOG_CSV=csv/polymarket_temperature_signals.csv
POLY_ORDER_STATE_JSON=csv/polymarket_temperature_order_state.json

# Bankroll / sizing
POLY_BANKROLL=40
POLY_MAX_TRADE_PCT=0.03
POLY_KELLY_FRACTION=0.25
POLY_LIVE_MIN_ORDER_SIZE=1.00
POLY_LIVE_MAX_ORDERS_PER_SCAN=5
POLY_LIVE_MAX_DOLLARS_PER_SCAN=5.00
POLY_MAX_ORDERS_PER_CITY_DATE=2

# Take profit / stop loss
POLY_DAILY_TAKE_PROFIT_PCT=0.80
POLY_TAKE_PROFIT_CLOSE_ALL_ENABLED=true
POLY_TAKE_PROFIT_CLOSE_SAME_DAY_ONLY=false
POLY_DAILY_STOP_LOSS_PCT=0.50

# Market filters
POLY_ALLOW_SIDE=AUTO
POLY_MIN_PRICE=0.04
POLY_MAX_PRICE=0.18
POLY_YES_MAX_PRICE=0.18
POLY_NO_MAX_PRICE=0.20
POLY_MIN_VOLUME=5000
POLY_MIN_DEPTH_MULTIPLIER=1.0

# YES: low-price asymmetric payoff mode
POLY_YES_MIN_EDGE=0.22
POLY_YES_MIN_EV=0.18
POLY_YES_MIN_SCORE=0.22
POLY_YES_EARLY_MAX_PRICE=0.08
POLY_YES_EARLY_SIZE_MULTIPLIER=0.45
POLY_YES_INTRADAY_ENABLED=true
POLY_YES_INTRADAY_CONFIRM_ABOVE_PRICE=0.10
POLY_YES_INTRADAY_CONFIRM_DISTANCE=0.80
POLY_YES_INTRADAY_MAX_DAYS_AHEAD=1

# Intraday METAR / station calibration / snapshots
POLY_METAR_ENABLED=true
POLY_NO_METAR_BLOCK_DISTANCE=1.00
POLY_NO_METAR_RISK_DISTANCE=1.50
POLY_STATION_CALIBRATION_ENABLED=true
POLY_STATION_CALIBRATION_JSON=csv\station_calibration.json
POLY_STATION_CALIBRATION_MIN_SAMPLES=8
POLY_STATION_CALIBRATION_MAX_ABS_SHIFT=0.06
POLY_SNAPSHOT_ENABLED=true
POLY_SNAPSHOT_DIR=csv\snapshots

POLY_YES_EXACT_EXTRA_EDGE=0.16
POLY_YES_EXACT_EXTRA_EV=0.16
POLY_YES_EXACT_MIN_CONFIDENCE=0.72
POLY_YES_EXACT_MIN_PRICE=0.04
POLY_YES_EXACT_MAX_DAYS_AHEAD=1
POLY_YES_EXACT_MAX_FORECAST_DISTANCE=0.60
POLY_YES_EXACT_MAX_HISTORY_GAP=0.12
POLY_YES_EXACT_MIN_HISTORY_PROB=0.18
POLY_YES_EXACT_MAX_HISTORY_MEAN_DISTANCE=0.90
POLY_YES_ABOVE_MIN_HISTORY_PROB=0.30
POLY_YES_EXACT_SIGNAL_MULTIPLIER=0.45
POLY_YES_CITY_BLACKLIST=

# NO: confirmation-oriented mode
POLY_NO_MIN_EDGE=0.16
POLY_NO_MIN_EV=0.25
POLY_NO_MIN_SCORE=0.18
POLY_NO_MAX_DAYS_AHEAD=0
POLY_NO_SIZE_MULTIPLIER=0.55
POLY_NO_EXACT_MIN_FORECAST_DISTANCE=1.20
POLY_NO_EXACT_MIN_HISTORY_NO_PROB=0.82

# Model
POLY_TEMP_BAND_C=2
POLY_PROBABILITY_SHRINK=0.70
POLY_HISTORY_ENABLED=true
POLY_HISTORY_WEIGHT=0.30
POLY_HISTORY_LOOKBACK_YEARS=5
POLY_HISTORY_WINDOW_DAYS=15

# Weather station alignment
# The bot extracts Weather Underground station codes from Polymarket resolutionSource
# when available, for example KSFO/KLAX/RKSI/RPLL, and uses station coordinates first.

# EV / score / sizing
POLY_NET_EV_SPREAD_WEIGHT=0.50
POLY_NET_EV_LOW_PRICE_CUTOFF=0.08
POLY_NET_EV_LOW_PRICE_PENALTY=0.01
POLY_EXACT_COST_PENALTY=0.03
POLY_HISTORY_GAP_REDUCE=0.18
POLY_HISTORY_GAP_HARD_CAP=0.25
POLY_STRONG_SIGNAL_EDGE=0.24
POLY_STRONG_SIGNAL_EV=0.35
POLY_STRONG_SIGNAL_CONFIDENCE=0.72
POLY_MAX_SIGNAL_MULTIPLIER=1.80
POLY_WEAK_SIGNAL_MULTIPLIER=0.50
POLY_EXACT_SIGNAL_MULTIPLIER=0.80
